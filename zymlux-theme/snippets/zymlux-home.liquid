#zx-bar a:hover{background:var(--btn-h)}
#zx-bar .lt{display:flex;align-items:baseline;flex-wrap:wrap}

#zx :where(a,button,summary,[tabindex]):focus-visible{outline:2px solid var(--gold);outline-offset:3px}

@media(max-width:860px){
