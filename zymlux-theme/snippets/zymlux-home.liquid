{%- comment -%} Zymlux — Serenity Acupressure Set · immersive editorial homepage (self-contained) {%- endcomment -%}
{%- assign purl = '/products/acupressure-mat-neck-pillow-set' -%}
{%- assign img = 'https://cdn.shopify.com/s/files/1/1012/8821/4857/files/' -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;1,9..144,300;1,9..144,400&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

<style>
#zx{
  --cream:#F4EFE7; --cream2:#ECE5D8; --paper:#FBF9F4;
  --ink:#2C3531; --ink2:#3E4A45; --muted:#4A554F; --soft:#6B746E;
  --clay:#C8704F; --clay-deep:#A85636; --btn:#B45F40; --btn-h:#9C4B2D; --on-btn:#FFF7EF;
  --sage:#7A8F78; --gold:#C9A57E;
  --line:rgba(62,74,69,.14); --line-2:rgba(62,74,69,.08); --line-d:rgba(244,239,231,.18);
  --serif:'Fraunces',Georgia,serif; --sans:'Inter','Helvetica Neue',Arial,sans-serif;
  --wide:1240px; --prose:620px; --head:780px;
  --pad-y:clamp(5.5rem,3rem + 10vw,11rem); --pad-x:clamp(1.4rem,0.5rem + 4vw,4rem);
  font-family:var(--sans); color:var(--muted); background:var(--cream);
  line-height:1.7; -webkit-font-smoothing:antialiased; text-rendering:optimizeLegibility;
  overflow-x:hidden;
}
#zx *{box-sizing:border-box;margin:0;padding:0}
#zx img{display:block;max-width:100%}
#zx ::selection{background:rgba(200,112,79,.2)}
#zx .serif{font-family:var(--serif)}
#zx h1,#zx h2,#zx h3{font-family:var(--serif);font-weight:300;color:var(--ink2);letter-spacing:-.02em;line-height:1.05}
#zx h1 em,#zx h2 em,#zx .em{font-style:italic;font-weight:300;color:var(--clay)}
#zx p{max-width:64ch}
#zx .lead{font-size:clamp(1.08rem,1rem + .5vw,1.32rem);line-height:1.6;color:var(--muted)}

#zx .eyebrow{display:inline-flex;align-items:center;gap:13px;font:500 .72rem/1 var(--sans);
  text-transform:uppercase;letter-spacing:.28em;color:var(--clay-deep)}
#zx .eyebrow::before{content:"";width:30px;height:1px;background:var(--clay)}
#zx .eyebrow.center{justify-content:center}
#zx .eyebrow.center::after{content:"";width:30px;height:1px;background:var(--clay)}
#zx .eyebrow.light{color:var(--gold)}
#zx .eyebrow.light::before,#zx .eyebrow.light.center::after{background:var(--gold)}

/* buttons */
#zx .btn{display:inline-flex;align-items:center;gap:11px;font:500 .9rem/1 var(--sans);
  letter-spacing:.06em;text-transform:uppercase;text-decoration:none;padding:18px 34px;cursor:pointer;
  border:1px solid transparent;transition:transform .4s cubic-bezier(.2,.7,.2,1),background .4s,color .4s,border-color .4s}
#zx .btn-primary{background:var(--btn);color:var(--on-btn)}
#zx .btn-primary:hover{background:var(--btn-h);transform:translateY(-3px)}
#zx .btn-light{background:var(--cream);color:var(--ink)}
#zx .btn-light:hover{background:#fff;transform:translateY(-3px)}
#zx .btn-ghost{background:transparent;color:var(--ink);border-color:var(--line)}
#zx .btn-ghost:hover{border-color:var(--ink);transform:translateY(-3px)}
#zx .btn-ghost.light{color:var(--cream);border-color:var(--line-d)}
#zx .btn-ghost.light:hover{border-color:var(--cream);background:rgba(255,255,255,.06)}
#zx .btn .arr{transition:transform .4s ease}
#zx .btn:hover .arr{transform:translateX(5px)}

#zx .ico{width:26px;height:26px;flex:none;stroke:var(--clay);fill:none;stroke-width:1.2;stroke-linecap:round;stroke-linejoin:round}
#zx .ico.sm{width:17px;height:17px}

/* reveal */
#zx .reveal{opacity:0;transform:translateY(26px);transition:opacity 1s cubic-bezier(.2,.6,.2,1),transform 1s cubic-bezier(.2,.6,.2,1)}
#zx .reveal.is-in{opacity:1;transform:none}
#zx .reveal.d1{transition-delay:.1s}#zx .reveal.d2{transition-delay:.2s}#zx .reveal.d3{transition-delay:.3s}

/* header */
#zx-head{position:absolute;top:0;left:0;right:0;z-index:30;display:flex;justify-content:center;
  padding:26px 20px;transition:background .4s,padding .4s,box-shadow .4s}
#zx-head .mark{font-family:var(--serif);font-weight:400;font-size:1.35rem;letter-spacing:.42em;
  color:var(--cream);padding-left:.42em;transition:color .4s}
#zx-head.solid{position:fixed;background:rgba(244,239,231,.92);-webkit-backdrop-filter:blur(12px);backdrop-filter:blur(12px);
  padding:16px 20px;box-shadow:0 1px 0 var(--line-2)}
#zx-head.solid .mark{color:var(--ink)}

/* HERO full-screen */
#zx .hero{position:relative;min-height:100svh;min-height:100vh;display:flex;align-items:flex-end;overflow:hidden}
#zx .hero-bg{position:absolute;inset:0;z-index:0}
#zx .hero-bg img{width:100%;height:100%;object-fit:cover;object-position:50% 32%;transform:scale(1.06);transition:transform 12s ease}
#zx .hero.is-in .hero-bg img{transform:scale(1)}
#zx .hero::after{content:"";position:absolute;inset:0;z-index:1;
  background:linear-gradient(180deg,rgba(30,36,33,.34) 0%,rgba(30,36,33,0) 26%,rgba(30,36,33,.12) 56%,rgba(30,36,33,.74) 100%)}
#zx .hero-inner{position:relative;z-index:2;width:100%;max-width:var(--wide);margin:0 auto;
  padding:0 var(--pad-x) clamp(3.5rem,7vw,6rem)}
#zx .hero-inner .eyebrow{color:var(--gold)}
#zx .hero-inner .eyebrow::before{background:var(--gold)}
#zx .hero h1{color:var(--cream);font-size:clamp(2.9rem,1.6rem + 6vw,5.8rem);margin:24px 0 0;max-width:16ch;
  text-shadow:0 2px 40px rgba(20,24,22,.3)}
#zx .hero h1 em{color:#F0C9B2}
#zx .hero-sub{color:rgba(244,239,231,.92);font-size:clamp(1.05rem,1rem + .5vw,1.3rem);line-height:1.6;
  margin:22px 0 0;max-width:42ch}
#zx .hero-row{display:flex;flex-wrap:wrap;align-items:center;gap:18px 28px;margin-top:36px}
#zx .hero-price{display:flex;align-items:baseline;gap:11px;color:var(--cream)}
#zx .hero-price .now{font-family:var(--serif);font-weight:400;font-size:1.7rem}
#zx .hero-price .was{font-size:.95rem;color:rgba(244,239,231,.6);text-decoration:line-through}
#zx .hero-scroll{position:absolute;left:50%;bottom:22px;z-index:2;transform:translateX(-50%);
  display:flex;flex-direction:column;align-items:center;gap:8px;color:rgba(244,239,231,.7);
  font:500 .64rem/1 var(--sans);text-transform:uppercase;letter-spacing:.24em}
#zx .hero-scroll i{width:1px;height:42px;background:linear-gradient(rgba(244,239,231,.7),rgba(244,239,231,0));animation:zxdrop 2.4s ease-in-out infinite}
@keyframes zxdrop{0%{opacity:0;transform:scaleY(.3);transform-origin:top}50%{opacity:1}100%{opacity:0;transform:scaleY(1);transform-origin:top}}

/* trust strip */
#zx .strip{background:var(--ink);color:var(--cream)}
#zx .strip .in{max-width:var(--wide);margin:0 auto;display:flex;flex-wrap:wrap;justify-content:center;align-items:center;
  gap:clamp(18px,4vw,60px);padding:22px var(--pad-x)}
#zx .strip span{display:inline-flex;align-items:center;gap:10px;font:500 .72rem/1 var(--sans);
  text-transform:uppercase;letter-spacing:.16em;color:rgba(244,239,231,.82)}
#zx .strip .ico{stroke:var(--gold);width:18px;height:18px}

/* section bases */
#zx .sec{padding:var(--pad-y) var(--pad-x)}
#zx .wrap{max-width:var(--wide);margin:0 auto}
#zx .section-head{max-width:var(--head);margin:0 auto;text-align:center}
#zx .section-head h2{font-size:clamp(2.1rem,1.5rem + 2.6vw,3.4rem);margin:20px 0 0}
#zx .section-head .lead{margin:22px auto 0}

/* DARK manifesto */
#zx .manifesto{background:var(--ink);color:var(--cream);text-align:center;padding:clamp(6rem,11vw,11rem) var(--pad-x)}
#zx .manifesto .inner{max-width:var(--head);margin:0 auto}
#zx .manifesto p{max-width:24ch;margin:34px auto 0;font-family:var(--serif);font-weight:300;
  font-size:clamp(1.7rem,1.2rem + 2.4vw,2.9rem);line-height:1.4;color:var(--cream)}
#zx .manifesto p .em{color:var(--gold)}
#zx .manifesto .rule{width:1px;height:54px;background:linear-gradient(var(--gold),transparent);margin:40px auto 0}

/* SPLIT band — image bleeds to screen edge */
#zx .split{display:grid;grid-template-columns:1fr 1fr;align-items:stretch;min-height:clamp(520px,72vh,760px)}
#zx .split .media{position:relative;overflow:hidden}
#zx .split .media img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
#zx .split .copy{display:flex;flex-direction:column;justify-content:center;padding:clamp(3rem,7vw,7rem) clamp(1.6rem,5vw,6rem)}
#zx .split .copy.pad-r{padding-right:clamp(1.6rem,7vw,8rem)}
#zx .split h2{font-size:clamp(2rem,1.4rem + 2.6vw,3.2rem);margin:20px 0 0}
#zx .split .lead{margin-top:22px}
#zx .split .body{margin-top:16px}
#zx .split.flip .media{order:2}

/* FULL-BLEED cinematic */
#zx .cine{position:relative;min-height:clamp(560px,86vh,860px);display:grid;place-items:center;text-align:center;overflow:hidden}
#zx .cine img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:50% 50%}
#zx .cine::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(28,33,30,.5),rgba(28,33,30,.34) 45%,rgba(28,33,30,.66))}
#zx .cine .bc{position:relative;z-index:2;max-width:680px;padding:48px var(--pad-x);color:var(--cream)}
#zx .cine h2{color:var(--cream);font-size:clamp(2.2rem,1.4rem + 3.4vw,4rem);margin:20px 0 0}
#zx .cine p{color:rgba(244,239,231,.92);margin:20px auto 0;max-width:44ch;font-size:1.05rem}
#zx .cine .btn{margin-top:34px}

/* benefits */
#zx .gives{background:var(--paper)}
#zx .gives-list{max-width:900px;margin:clamp(2.5rem,5vw,4rem) auto 0;display:grid;gap:0}
#zx .give{display:grid;grid-template-columns:auto 1fr auto;gap:30px;align-items:center;
  padding:clamp(26px,3.5vw,40px) 0;border-top:1px solid var(--line)}
#zx .give:last-child{border-bottom:1px solid var(--line)}
#zx .give .ic{width:60px;height:60px;border-radius:50%;background:var(--cream2);display:grid;place-items:center}
#zx .give .tx h3{font-size:1.4rem;font-weight:400;margin:0}
#zx .give .tx p{margin-top:7px;max-width:48ch;color:var(--muted)}
#zx .give .idx{font-family:var(--serif);font-weight:300;font-size:1.5rem;color:var(--gold)}
@media(max-width:620px){#zx .give .idx{display:none}}

/* steps */
#zx .steps{max-width:1000px;margin:clamp(2.5rem,5vw,4rem) auto 0;display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(2rem,4vw,3.5rem)}
#zx .step .num{font-family:var(--serif);font-weight:300;font-size:2.6rem;color:var(--clay);line-height:1}
#zx .step .br{width:36px;height:1px;background:var(--line);margin:18px 0}
#zx .step h3{font-size:1.35rem;font-weight:400;margin:0 0 8px}
#zx .step p{font-size:1rem;color:var(--muted)}

/* founder DARK */
#zx .founder{background:var(--ink);color:var(--cream);text-align:center;padding:clamp(5.5rem,10vw,10rem) var(--pad-x)}
#zx .founder .inner{max-width:var(--head);margin:0 auto}
#zx .founder blockquote{font-family:var(--serif);font-weight:300;font-style:italic;
  font-size:clamp(1.4rem,1.1rem + 1.5vw,2.05rem);line-height:1.5;color:var(--cream);max-width:40ch;margin:30px auto 0}
#zx .founder .sign{display:block;margin:34px auto 0;width:140px;height:auto;stroke:var(--gold);fill:none;stroke-width:1.3}
#zx .founder .who{margin-top:16px;font:500 .76rem/1 var(--sans);letter-spacing:.18em;text-transform:uppercase;color:var(--gold)}

/* trial */
#zx .trial{text-align:center;background:var(--cream2)}
#zx .trial .seal{width:120px;height:120px;border-radius:50%;border:1px solid var(--clay);margin:0 auto 30px;
  display:grid;place-content:center;text-align:center;color:var(--clay)}
#zx .trial .seal b{font-family:var(--serif);font-weight:300;font-size:2.3rem;line-height:.9;color:var(--ink2)}
#zx .trial .seal small{font:500 .58rem/1 var(--sans);letter-spacing:.2em;text-transform:uppercase;margin-top:5px;color:var(--clay-deep)}
#zx .trial h2{font-size:clamp(2.1rem,1.5rem + 2.6vw,3.2rem)}
#zx .trial p{max-width:46ch;margin:22px auto 0}
#zx .trial .btn{margin-top:34px}

/* reviews honest */
#zx .reviews{text-align:center}
#zx .reviews .inner{max-width:var(--prose);margin:0 auto}
#zx .reviews h2{font-size:clamp(1.9rem,1.4rem + 1.8vw,2.7rem);margin:18px 0 0}
#zx .reviews p{margin:20px auto 0}
#zx .reviews .stars{display:inline-flex;gap:8px;margin-top:26px}
#zx .reviews .stars .ico{stroke:var(--clay);width:22px;height:22px}

/* faq */
#zx .faq{max-width:760px;margin:clamp(2.5rem,5vw,3.5rem) auto 0}
#zx details{border-bottom:1px solid var(--line)}
#zx summary{display:flex;align-items:center;justify-content:space-between;gap:20px;padding:26px 4px;cursor:pointer;
  list-style:none;font:400 1.2rem/1.4 var(--serif);color:var(--ink2)}
#zx summary::-webkit-details-marker{display:none}
#zx summary .chev{transition:transform .3s ease;flex:none}
#zx details[open] summary .chev{transform:rotate(180deg)}
#zx .faq .ans p{padding:0 4px 26px;max-width:64ch;color:var(--muted)}

/* final cinematic */
#zx .final{position:relative;min-height:clamp(560px,80vh,800px);display:grid;place-items:center;text-align:center;overflow:hidden}
#zx .final img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:50% 40%}
#zx .final::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(28,33,30,.55),rgba(28,33,30,.72))}
#zx .final .bc{position:relative;z-index:2;max-width:680px;padding:48px var(--pad-x);color:var(--cream)}
#zx .final h2{color:var(--cream);font-size:clamp(2.3rem,1.5rem + 3.4vw,4.2rem);margin:20px auto 0;max-width:16ch}
#zx .final p{color:rgba(244,239,231,.9);margin:22px auto 0}
#zx .final .btn{margin-top:34px}

/* sticky bar */
#zx-bar{position:fixed;left:0;right:0;bottom:0;z-index:60;background:rgba(244,239,231,.95);
  -webkit-backdrop-filter:blur(12px);backdrop-filter:blur(12px);border-top:1px solid var(--line);
  transform:translateY(105%);transition:transform .45s cubic-bezier(.2,.7,.2,1)}
#zx-bar.show{transform:none}
#zx-bar .in{max-width:var(--wide);margin:0 auto;display:flex;align-items:center;justify-content:space-between;
  gap:18px;padding:12px var(--pad-x) calc(12px + env(safe-area-inset-bottom));font-family:var(--sans)}
#zx-bar .nm{font-family:var(--serif);font-weight:400;font-size:1.08rem;color:var(--ink2)}
#zx-bar .pr{font-size:.95rem;color:var(--soft);margin-left:10px}
#zx-bar a{display:inline-flex;align-items:center;gap:9px;background:var(--btn);color:var(--on-btn);text-decoration:none;
  font:500 .8rem/1 var(--sans);letter-spacing:.06em;text-transform:uppercase;padding:14px 26px;white-space:nowrap;transition:background .3s}
#zx-bar a:hover{background:var(--btn-h)}
#zx-bar .lt{display:flex;align-items:baseline;flex-wrap:wrap}

#zx :where(a,button,summary,[tabindex]):focus-visible{outline:2px solid var(--clay);outline-offset:3px}

@media(max-width:860px){
  #zx .split{grid-template-columns:1fr}
  #zx .split .media{min-height:62vh}
  #zx .split.flip .media{order:0}
  #zx .steps{grid-template-columns:1fr;gap:36px}
  #zx .give{grid-template-columns:auto 1fr;gap:20px}
}
@media(prefers-reduced-motion:reduce){
  #zx *,#zx *::before,#zx *::after{animation:none!important;transition:none!important}
  #zx .reveal{opacity:1!important;transform:none!important}
  #zx .hero-bg img{transform:none!important}
  #zx-bar,#zx-head{transition:none!important}
}
</style>

<svg width="0" height="0" style="position:absolute" aria-hidden="true" focusable="false">
  <symbol id="zxi-moon" viewBox="0 0 24 24"><path d="M21 12.8A8.5 8.5 0 1 1 11.2 3 6.6 6.6 0 0 0 21 12.8Z"/></symbol>
  <symbol id="zxi-shield" viewBox="0 0 24 24"><path d="M12 3l7 3v5c0 4.4-3 7.5-7 9-4-1.5-7-4.6-7-9V6l7-3Z"/><path d="M9 12l2 2 4-4"/></symbol>
  <symbol id="zxi-truck" viewBox="0 0 24 24"><path d="M3 7h11v8H3zM14 10h4l3 3v2h-7z"/><circle cx="7" cy="17.5" r="1.6"/><circle cx="17.5" cy="17.5" r="1.6"/></symbol>
  <symbol id="zxi-lock" viewBox="0 0 24 24"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></symbol>
  <symbol id="zxi-leaf" viewBox="0 0 24 24"><path d="M5 19c0-8 6-13 14-13 0 8-5 14-14 13Z"/><path d="M5 19c3-4 6-6 10-7.5"/></symbol>
  <symbol id="zxi-release" viewBox="0 0 24 24"><path d="M4 12h5M20 12h-5"/><path d="M7 8l-3 4 3 4M17 8l3 4-3 4"/></symbol>
  <symbol id="zxi-rest" viewBox="0 0 24 24"><path d="M3 17v-3a3 3 0 0 1 3-3h12a3 3 0 0 1 3 3v3"/><path d="M3 17h18M7 11V9a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v2"/></symbol>
  <symbol id="zxi-chev" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></symbol>
  <symbol id="zxi-star" viewBox="0 0 24 24"><path d="M12 4l2.3 4.7 5.2.8-3.8 3.7.9 5.1L12 16l-4.6 2.4.9-5.1L4.5 9.5l5.2-.8L12 4Z"/></symbol>
  <symbol id="zxi-arrow" viewBox="0 0 24 24"><path d="M5 12h13M13 6l6 6-6 6"/></symbol>
</svg>

<header id="zx-head"><span class="mark">ZYMLUX</span></header>

<div id="zx">

  <!-- HERO full-screen -->
  <section class="hero" id="zxhero">
    <div class="hero-bg"><img src="{{ img }}pexels-photo-6453915.jpg?v=1782829005&amp;width=1800" alt="A woman resting calmly in soft morning light" width="1800" height="2250" loading="eager" fetchpriority="high" decoding="async"></div>
    <div class="hero-inner">
      <span class="eyebrow">The Serenity Set &#183; Acupressure ritual</span>
      <h1>Twenty quiet minutes, and the day <em>lets go</em>.</h1>
      <p class="hero-sub">An acupressure mat and contoured neck pillow, made for the slow hour between the day and sleep.</p>
      <div class="hero-row">
        <a href="{{ purl }}" class="btn btn-light">Begin the ritual <svg class="ico sm arr" style="stroke:currentColor"><use href="#zxi-arrow"></use></svg></a>
        <span class="hero-price"><span class="now">$49.99</span><span class="was">$99.99</span></span>
      </div>
    </div>
    <div class="hero-scroll"><span>Scroll</span><i></i></div>
  </section>

  <!-- TRUST STRIP -->
  <section class="strip">
    <div class="in">
      <span><svg class="ico"><use href="#zxi-truck"></use></svg> Free US shipping</span>
      <span><svg class="ico"><use href="#zxi-shield"></use></svg> 60-night trial</span>
      <span><svg class="ico"><use href="#zxi-lock"></use></svg> Secure checkout</span>
      <span><svg class="ico"><use href="#zxi-leaf"></use></svg> Drug-free</span>
    </div>
  </section>

  <!-- DARK MANIFESTO -->
  <section class="manifesto">
    <div class="inner reveal">
      <span class="eyebrow center light">The ritual</span>
      <p>Lie down. Let the points meet your skin. Breathe until the day <span class="em">loosens its grip</span>.</p>
      <div class="rule"></div>
    </div>
  </section>

  <!-- PROBLEM split -->
  <section class="split">
    <div class="media reveal"><img src="{{ img }}pexels-photo-3822622.jpg?v=1782829094&amp;width=1100" alt="A woman easing tension in her neck and shoulders" width="1100" height="1375" loading="lazy" decoding="async"></div>
    <div class="copy pad-r reveal d1">
      <span class="eyebrow">The evening you know</span>
      <h2>You carry the day in your shoulders.</h2>
      <p class="lead">A tight neck. A mind still running. The body braced long after the work is done.</p>
      <p class="body">The Serenity Set gives all of it somewhere to land &#8212; a few honest minutes that tell the nervous system it&#39;s finally safe to rest.</p>
    </div>
  </section>

  <!-- BENEFITS -->
  <section class="sec gives">
    <div class="section-head reveal">
