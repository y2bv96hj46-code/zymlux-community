<style>
#zx{
  --cream:#F4EFE7; --cream2:#ECE5D8; --paper:#FBF9F4;
  --ink:#3E4A45; --muted:#4A554F; --soft:#6B746E;
  --clay:#C8704F; --clay-deep:#A85636; --btn:#B45F40; --btn-h:#9C4B2D; --on-btn:#FFF7EF;
  --sage:#7A8F78; --line:rgba(62,74,69,.14); --line-2:rgba(62,74,69,.08);
  --serif:'Fraunces',Georgia,serif; --sans:'Inter','Helvetica Neue',Arial,sans-serif;
  --wide:1200px; --prose:640px; --head:760px;
  --pad-y:clamp(5rem,3rem + 9vw,10rem); --pad-x:clamp(1.5rem,0.5rem + 4vw,3.5rem);
  font-family:var(--sans); color:var(--muted); background:var(--cream);
  line-height:1.7; -webkit-font-smoothing:antialiased; text-rendering:optimizeLegibility;
  overflow-x:hidden;
}
#zx *{box-sizing:border-box;margin:0;padding:0}
#zx img{display:block;max-width:100%}
#zx ::selection{background:rgba(200,112,79,.18)}
#zx .wrap{width:100%;max-width:var(--wide);margin-inline:auto;padding-inline:var(--pad-x)}
#zx .serif{font-family:var(--serif);font-weight:300;color:var(--ink);letter-spacing:-.015em;line-height:1.08}
#zx .eyebrow{display:inline-flex;align-items:center;gap:12px;font:500 .75rem/1 var(--sans);
  text-transform:uppercase;letter-spacing:.22em;color:var(--clay-deep)}
#zx .eyebrow::before{content:"";width:26px;height:1px;background:var(--clay);display:inline-block}
#zx .eyebrow.center{justify-content:center}
#zx h1,#zx h2,#zx h3{font-family:var(--serif);font-weight:300;color:var(--ink);letter-spacing:-.018em;line-height:1.06}
#zx h1 em,#zx h2 em{font-style:italic;font-weight:300;color:var(--clay-deep)}
#zx p{max-width:68ch}
#zx .lead{font-size:clamp(1.06rem,1rem + .4vw,1.28rem);line-height:1.6;color:var(--muted)}

/* buttons */
#zx .btn{display:inline-flex;align-items:center;gap:10px;font:500 .94rem/1 var(--sans);
  letter-spacing:.03em;text-decoration:none;padding:16px 30px;border-radius:3px;cursor:pointer;
  border:1px solid transparent;transition:transform .35s cubic-bezier(.2,.7,.2,1),background .35s,color .35s,border-color .35s}
#zx .btn-primary{background:var(--btn);color:var(--on-btn)}
#zx .btn-primary:hover{background:var(--btn-h);transform:translateY(-2px)}
#zx .btn-ghost{background:transparent;color:var(--ink);border-color:var(--line)}
#zx .btn-ghost:hover{border-color:var(--ink);transform:translateY(-2px)}
#zx .btn .arr{transition:transform .35s ease}
#zx .btn:hover .arr{transform:translateX(4px)}
#zx .reassure{margin-top:16px;font:400 .8rem/1.5 var(--sans);letter-spacing:.02em;color:var(--soft)}

/* icons */
#zx .ico{width:28px;height:28px;flex:none;stroke:var(--clay);fill:none;stroke-width:1.25;
  stroke-linecap:round;stroke-linejoin:round}
#zx .ico.sm{width:18px;height:18px}

/* reveal */
#zx .reveal{opacity:0;transform:translateY(22px);transition:opacity .9s cubic-bezier(.2,.6,.2,1),transform .9s cubic-bezier(.2,.6,.2,1)}
#zx .reveal.is-in{opacity:1;transform:none}
#zx .reveal.d1{transition-delay:.09s}#zx .reveal.d2{transition-delay:.18s}#zx .reveal.d3{transition-delay:.27s}

/* hero */
#zx .hero{display:grid;grid-template-columns:1fr 1fr;align-items:center;gap:clamp(2rem,5vw,5rem);
  max-width:var(--wide);margin-inline:auto;padding:clamp(3.5rem,6vw,7rem) var(--pad-x) clamp(3rem,5vw,5.5rem)}
#zx .hero-copy{max-width:520px}
#zx .hero h1{font-size:clamp(2.6rem,1.7rem + 4.4vw,4.6rem);margin:26px 0 0}
#zx .hero .lead{margin:24px 0 0;max-width:40ch}
#zx .hero-price{display:flex;align-items:baseline;gap:12px;margin:30px 0 0}
#zx .hero-price .now{font-family:var(--serif);font-weight:400;font-size:1.65rem;color:var(--ink);font-feature-settings:'tnum' 1}
#zx .hero-price .was{font-size:.95rem;color:var(--soft);text-decoration:line-through;text-decoration-color:var(--clay)}
#zx .hero-price .note{font-size:.78rem;letter-spacing:.04em;color:var(--soft)}
#zx .hero-cta{margin-top:26px}
#zx .hero-trust{display:flex;flex-wrap:wrap;gap:22px;margin-top:40px;padding-top:26px;border-top:1px solid var(--line-2)}
#zx .hero-trust span{display:inline-flex;align-items:center;gap:9px;font:500 .76rem/1 var(--sans);
  text-transform:uppercase;letter-spacing:.12em;color:var(--soft)}
#zx .hero-trust .ico{stroke:var(--sage)}
#zx .hero-media{position:relative;border-radius:4px;overflow:hidden;aspect-ratio:4/5;
  box-shadow:0 50px 90px -50px rgba(62,74,69,.6)}
#zx .hero-media img{width:100%;height:100%;object-fit:cover;object-position:50% 30%;
  transform:scale(1.04);transition:transform 9s ease}
#zx .hero-media.is-in img{transform:scale(1)}

/* strip */
#zx .strip{background:var(--cream2);border-top:1px solid var(--line-2);border-bottom:1px solid var(--line-2)}
#zx .strip .wrap{display:flex;flex-wrap:wrap;justify-content:center;align-items:center;
  gap:clamp(16px,4vw,56px);padding-top:20px;padding-bottom:20px}
#zx .strip span{display:inline-flex;align-items:center;gap:10px;font:500 .76rem/1 var(--sans);
  text-transform:uppercase;letter-spacing:.13em;color:var(--soft)}
#zx .strip .ico{stroke:var(--sage)}

/* ritual / manifesto */
#zx .ritual{text-align:center;padding:var(--pad-y) var(--pad-x)}
#zx .ritual .inner{max-width:var(--head);margin-inline:auto}
#zx .ritual p{max-width:46ch;margin:30px auto 0;font-family:var(--serif);font-weight:300;
  font-size:clamp(1.5rem,1.2rem + 1.4vw,2.05rem);line-height:1.5;color:var(--ink)}
#zx .ritual .rule{width:48px;height:1px;background:var(--clay);margin:38px auto 0}

/* image + copy bands */
#zx .band{display:grid;grid-template-columns:1fr 1fr;align-items:center;gap:clamp(2rem,5vw,5.5rem);
  max-width:var(--wide);margin-inline:auto;padding:var(--pad-y) var(--pad-x)}
#zx .band-media{border-radius:4px;overflow:hidden;aspect-ratio:4/5;box-shadow:0 44px 80px -48px rgba(62,74,69,.55)}
#zx .band-media img{width:100%;height:100%;object-fit:cover}
#zx .band h2{font-size:clamp(2rem,1.5rem + 2.2vw,3.1rem);margin:22px 0 0}
#zx .band .lead{margin-top:22px}
#zx .band.flip .band-media{order:2}

/* benefits */
#zx .gives{background:var(--paper);padding:var(--pad-y) var(--pad-x)}
#zx .section-head{max-width:var(--head);margin:0 auto 0;text-align:center}
#zx .section-head h2{font-size:clamp(2rem,1.5rem + 2.2vw,3.1rem);margin:20px 0 0}
#zx .gives-list{max-width:820px;margin:clamp(2.5rem,5vw,4rem) auto 0;display:grid;gap:0}
#zx .give{display:grid;grid-template-columns:auto 1fr;gap:28px;align-items:start;
  padding:clamp(28px,4vw,44px) 0;border-top:1px solid var(--line)}
#zx .give:last-child{border-bottom:1px solid var(--line)}
#zx .give .ic{width:56px;height:56px;border-radius:50%;background:var(--cream2);
  display:grid;place-items:center}
#zx .give h3{font-size:1.32rem;font-weight:400;margin:0}
#zx .give p{margin-top:8px;max-width:46ch;color:var(--muted)}

/* steps */
#zx .steps-sec{padding:var(--pad-y) var(--pad-x)}
#zx .steps{max-width:980px;margin:clamp(2.5rem,5vw,4rem) auto 0;display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(2rem,4vw,3.5rem)}
#zx .step .num{font-family:var(--serif);font-weight:300;font-size:2.4rem;color:var(--clay);
  font-feature-settings:'tnum' 1;line-height:1}
#zx .step .br{width:34px;height:1px;background:var(--line);margin:18px 0}
#zx .step h3{font-size:1.3rem;font-weight:400;margin:0 0 8px}
#zx .step p{font-size:1rem;color:var(--muted)}

/* full-bleed */
#zx .bleed{position:relative;min-height:clamp(420px,68vh,680px);display:grid;place-items:center;text-align:center;overflow:hidden}
#zx .bleed img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:50% 50%}
#zx .bleed::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(38,46,42,.32),rgba(38,46,42,.52))}
#zx .bleed .bc{position:relative;z-index:2;max-width:var(--prose);padding:48px 28px}
#zx .bleed .eyebrow{color:#E7C7B5;justify-content:center}
#zx .bleed .eyebrow::before{background:#E7C7B5}
#zx .bleed h2{color:#FBF9F4;font-size:clamp(2rem,1.5rem + 2.6vw,3.2rem);margin:18px 0 0}
#zx .bleed p{color:rgba(251,249,244,.9);margin:18px auto 0;max-width:42ch}

/* founder */
#zx .founder{background:var(--cream2);padding:var(--pad-y) var(--pad-x)}
#zx .founder .inner{max-width:var(--head);margin-inline:auto;text-align:center}
#zx .founder blockquote{font-family:var(--serif);font-weight:300;font-style:italic;
  font-size:clamp(1.35rem,1.1rem + 1.1vw,1.85rem);line-height:1.45;color:var(--ink);
  max-width:42ch;margin:26px auto 0}
#zx .founder .sign{display:block;margin:30px auto 0;width:128px;height:auto;stroke:var(--ink);fill:none;stroke-width:1.4;opacity:.85}
#zx .founder .who{margin-top:14px;font:500 .82rem/1 var(--sans);letter-spacing:.06em;color:var(--soft)}

/* trial */
#zx .trial{text-align:center;padding:var(--pad-y) var(--pad-x)}
#zx .trial .rule{width:48px;height:1px;background:var(--clay);margin:0 auto 30px}
#zx .trial h2{font-size:clamp(2rem,1.5rem + 2.2vw,3rem)}
#zx .trial p{max-width:46ch;margin:22px auto 0}
#zx .trial .btn{margin-top:34px}

/* reviews honest */
#zx .reviews{background:var(--paper);padding:var(--pad-y) var(--pad-x);text-align:center}
#zx .reviews .inner{max-width:var(--prose);margin-inline:auto}
#zx .reviews h2{font-size:clamp(1.8rem,1.4rem + 1.8vw,2.6rem);margin:18px 0 0}
#zx .reviews p{margin:20px auto 0}
#zx .reviews .stars{display:inline-flex;gap:7px;margin-top:26px}
#zx .reviews .stars .ico{stroke:var(--clay);width:20px;height:20px}

/* faq */
#zx .faq-sec{padding:var(--pad-y) var(--pad-x)}
#zx .faq{max-width:720px;margin:clamp(2.5rem,5vw,3.5rem) auto 0}
#zx details{border-bottom:1px solid var(--line)}
#zx summary{display:flex;align-items:center;justify-content:space-between;gap:20px;
  padding:24px 4px;cursor:pointer;list-style:none;font:400 1.15rem/1.4 var(--serif);color:var(--ink)}
#zx summary::-webkit-details-marker{display:none}
#zx summary .chev{transition:transform .3s ease;flex:none}
#zx details[open] summary .chev{transform:rotate(180deg)}
#zx .faq .ans{overflow:hidden}
#zx .faq .ans p{padding:0 4px 26px;max-width:62ch;color:var(--muted)}

/* final */
#zx .final{text-align:center;padding:var(--pad-y) var(--pad-x);background:radial-gradient(120% 100% at 50% 0,var(--paper),var(--cream2))}
#zx .final h2{font-size:clamp(2.1rem,1.5rem + 2.6vw,3.4rem);max-width:18ch;margin:18px auto 0}
#zx .final p{margin:22px auto 0}
#zx .final .btn{margin-top:34px}

/* sticky bar */
#zx-bar{position:fixed;left:0;right:0;bottom:0;z-index:60;background:rgba(244,239,231,.94);
  -webkit-backdrop-filter:blur(12px);backdrop-filter:blur(12px);border-top:1px solid var(--line);
  transform:translateY(105%);transition:transform .45s cubic-bezier(.2,.7,.2,1)}
#zx-bar.show{transform:none}
#zx-bar .in{max-width:var(--wide);margin-inline:auto;display:flex;align-items:center;justify-content:space-between;
  gap:18px;padding:12px 20px calc(12px + env(safe-area-inset-bottom));font-family:'Inter',sans-serif}
#zx-bar .nm{font-family:'Fraunces',serif;font-weight:300;font-size:1.05rem;color:#3E4A45}
#zx-bar .pr{font-size:.95rem;color:#4A554F;margin-left:10px}
#zx-bar a{display:inline-flex;align-items:center;gap:9px;background:#B45F40;color:#FFF7EF;text-decoration:none;
  font:500 .9rem/1 'Inter',sans-serif;letter-spacing:.03em;padding:13px 26px;border-radius:3px;white-space:nowrap;transition:background .3s}
#zx-bar a:hover{background:#9C4B2D}
#zx-bar .lt{display:flex;align-items:baseline;flex-wrap:wrap}

/* focus */
#zx :where(a,button,summary,[tabindex]):focus-visible{outline:2px solid var(--clay);outline-offset:3px;border-radius:4px}

/* responsive */
@media(max-width:880px){
  #zx .hero{grid-template-columns:1fr;gap:0}
  #zx .hero-media{order:-1;aspect-ratio:5/4;margin-bottom:34px}
  #zx .hero-copy{max-width:none}
  #zx .hero-trust{justify-content:flex-start}
  #zx .band{grid-template-columns:1fr;gap:30px}
  #zx .band-media{aspect-ratio:16/11}
  #zx .band.flip .band-media{order:0}
  #zx .steps{grid-template-columns:1fr;gap:38px}
  #zx .give{grid-template-columns:1fr;gap:14px}
}
@media(prefers-reduced-motion:reduce){
  #zx *,#zx *::before,#zx *::after{animation:none!important;transition:none!important}
  #zx .reveal{opacity:1!important;transform:none!important}
  #zx .hero-media img{transform:none!important}
  #zx-bar{transition:none!important}
}
</style>

<svg width="0" height="0" style="position:absolute" aria-hidden="true" focusable="false">
  <symbol id="zxi-moon" viewBox="0 0 24 24"><path d="M21 12.8A8.5 8.5 0 1 1 11.2 3 6.6 6.6 0 0 0 21 12.8Z"/></symbol>
