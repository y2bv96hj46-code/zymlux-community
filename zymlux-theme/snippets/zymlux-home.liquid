  <symbol id="zxi-rest" viewBox="0 0 24 24"><path d="M3 17v-3a3 3 0 0 1 3-3h12a3 3 0 0 1 3 3v3"/><path d="M3 17h18M7 11V9a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v2"/></symbol>
  <symbol id="zxi-chev" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></symbol>
