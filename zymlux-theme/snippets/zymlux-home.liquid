<script>
(function(){
  var zx=document.getElementById('zx');if(!zx)return;
  var reduce=window.matchMedia&&window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* reveal + counters */
  function runCount(el){
    var to=+el.getAttribute('data-to'),t0=null,dur=1700;
    function step(ts){if(!t0)t0=ts;var p=Math.min((ts-t0)/dur,1);var e=1-Math.pow(1-p,3);
      var v=Math.floor(e*to);el.textContent=(to>=1000?v.toLocaleString('en-US'):v);
      if(p<1)requestAnimationFrame(step);else el.textContent=(to>=1000?to.toLocaleString('en-US'):to);}
    requestAnimationFrame(step);
  }
  var items=zx.querySelectorAll('.reveal,.cliprv');
  if(reduce||!('IntersectionObserver'in window)){
    items.forEach(function(el){el.classList.add('is-in');});
    zx.querySelectorAll('.cnt').forEach(function(c){c.textContent=(+c.getAttribute('data-to')).toLocaleString('en-US');});
  } else {
    var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){
      e.target.classList.add('is-in');
      var c=e.target.querySelector&&e.target.querySelector('.cnt');if(c&&!c.dataset.done){c.dataset.done=1;runCount(c);}
      io.unobserve(e.target);}});},{threshold:.12,rootMargin:'0px 0px -7% 0px'});
    items.forEach(function(el){io.observe(el);});
  }
  var hero=document.getElementById('zxhero');if(hero)hero.classList.add('is-in');

  /* parallax */
  var pe=[].slice.call(zx.querySelectorAll('[data-px]')),ticking=false;
  function px(){ticking=false;var vh=window.innerHeight;
    for(var i=0;i<pe.length;i++){var el=pe[i],r=el.getBoundingClientRect();
      if(r.bottom<-300||r.top>vh+300)continue;
      var prog=(r.top+r.height/2-vh/2)/(vh/2+r.height/2);if(prog>1)prog=1;if(prog<-1)prog=-1;
      var f=parseFloat(el.getAttribute('data-px'))||40;el.style.transform='translate3d(0,'+(-prog*f).toFixed(1)+'px,0)';}}
  function onPx(){if(!ticking){ticking=true;requestAnimationFrame(px);}}
  if(!reduce){window.addEventListener('scroll',onPx,{passive:true});window.addEventListener('resize',onPx,{passive:true});px();}

  /* sticky bar + header */
  var bar=document.getElementById('zx-bar'),head=document.getElementById('zx-head');
  function chrome(){var b=hero?hero.getBoundingClientRect().bottom:0;
    if(b<80){bar&&bar.classList.add('show');head&&head.classList.add('solid');}
    else{bar&&bar.classList.remove('show');head&&head.classList.remove('solid');}}
  window.addEventListener('scroll',chrome,{passive:true});chrome();

  /* menu */
  var menu=document.getElementById('zx-menu'),burger=document.getElementById('zx-burger'),
      closeb=menu&&menu.querySelector('.x');
  function setMenu(open){if(!menu)return;menu.classList.toggle('open',open);
    menu.setAttribute('aria-hidden',open?'false':'true');burger&&burger.setAttribute('aria-expanded',open?'true':'false');
    document.body.classList.toggle('zx-lock',open);}
  burger&&burger.addEventListener('click',function(){setMenu(true);});
  closeb&&closeb.addEventListener('click',function(){setMenu(false);});
  menu&&menu.querySelectorAll('nav a').forEach(function(a){a.addEventListener('click',function(){setMenu(false);});});
  document.addEventListener('keydown',function(e){if(e.key==='Escape')setMenu(false);});

  /* announcement rotation */
  var pm=document.querySelectorAll('#zx-promo .pm');
  if(pm.length>1){var pmi=0;setInterval(function(){pm[pmi].classList.remove('on');pmi=(pmi+1)%pm.length;pm[pmi].classList.add('on');},4200);}
})();
</script>
