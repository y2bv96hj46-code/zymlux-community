{%- comment -%} Zymlux — product story (self-contained, matches homepage design language) {%- endcomment -%}
{%- assign img = 'https://cdn.shopify.com/s/files/1/1012/8821/4857/files/' -%}

<style>
#zxs{--cream:#F4EFE7;--cream2:#EBE3D5;--paper:#FBF9F4;--ink:#1F2723;--ink2:#36423C;--muted:#4A554F;--soft:#6B746E;
  --clay:#C0683F;--clay-deep:#9E4F2E;--gold:#C2A06A;--gold2:#E3CBA0;
  --line:rgba(43,52,46,.14);--line-d:rgba(244,239,231,.16);
  --serif:'Fraunces',Georgia,serif;--sans:'Inter','Helvetica Neue',Arial,sans-serif;
  font-family:var(--sans);color:var(--muted);line-height:1.7;overflow:hidden;background:var(--cream);
  -webkit-font-smoothing:antialiased}
#zxs *{box-sizing:border-box;margin:0;padding:0}
#zxs img{display:block;max-width:100%}
#zxs h2,#zxs h3{font-family:var(--serif);font-weight:300;color:var(--ink2);letter-spacing:-.02em;line-height:1.1}
#zxs .em{font-style:italic;font-weight:300;color:var(--clay)}
#zxs .grad{background:linear-gradient(95deg,var(--gold2),var(--gold) 55%,var(--clay));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;color:transparent;font-style:italic}
#zxs .eyebrow{display:inline-flex;align-items:center;gap:13px;font:500 .72rem/1 var(--sans);text-transform:uppercase;letter-spacing:.3em;color:var(--gold)}
#zxs .eyebrow::before{content:"";width:30px;height:1px;background:var(--gold)}
#zxs .eyebrow.center::after{content:"";width:30px;height:1px;background:var(--gold)}
#zxs .reveal{opacity:0;transform:translateY(26px);transition:opacity 1s cubic-bezier(.2,.6,.2,1),transform 1s cubic-bezier(.2,.6,.2,1)}
#zxs .reveal.is-in{opacity:1;transform:none}
#zxs .reveal.d1{transition-delay:.12s}#zxs .reveal.d2{transition-delay:.24s}
#zxs .cliprv{clip-path:inset(0 0 100% 0);transition:clip-path 1.3s cubic-bezier(.2,.7,.2,1)}
#zxs .cliprv.is-in{clip-path:inset(0 0 0 0)}
#zxs .pwrap{position:relative;overflow:hidden}
#zxs .pimg{position:absolute;left:0;top:-14%;width:100%;height:128%;object-fit:cover;will-change:transform;backface-visibility:hidden}

/* manifesto */
#zxs .manif{background:var(--ink);color:var(--cream);text-align:center;padding:clamp(5rem,9vw,8.5rem) clamp(1.4rem,4vw,4rem)}
#zxs .manif p{max-width:26ch;margin:30px auto 0;font-family:var(--serif);font-weight:300;font-size:clamp(1.6rem,1.1rem + 2.4vw,2.7rem);line-height:1.35;color:var(--cream)}
#zxs .manif .rule{width:1px;height:50px;background:linear-gradient(var(--gold),transparent);margin:36px auto 0}

/* splits */
#zxs .split{display:grid;grid-template-columns:1fr 1fr;align-items:stretch;min-height:clamp(480px,72vh,740px)}
#zxs .split .media{position:relative;overflow:hidden}
#zxs .split .copy{display:flex;flex-direction:column;justify-content:center;padding:clamp(3rem,6vw,6rem) clamp(1.6rem,5vw,5.5rem)}
#zxs .split h2{font-size:clamp(1.9rem,1.3rem + 2.4vw,3rem);margin:18px 0 0}
#zxs .split .lead{margin-top:20px;font-size:clamp(1.05rem,1rem + .4vw,1.25rem);line-height:1.6}
#zxs .split.flip .media{order:2}
#zxs .steps{margin-top:30px;display:grid;gap:20px}
#zxs .step{display:grid;grid-template-columns:auto 1fr;gap:18px;align-items:baseline}
#zxs .step .num{font-family:var(--serif);font-weight:300;font-size:1.7rem;color:var(--clay);line-height:1}
#zxs .step h3{font-size:1.15rem;font-weight:400}
#zxs .step p{font-size:.95rem;margin-top:4px}
#zxs .boxlist{margin-top:26px;border-top:1px solid var(--line)}
#zxs .boxlist .row{display:flex;justify-content:space-between;gap:16px;padding:13px 2px;border-bottom:1px solid var(--line);font-size:.95rem}
#zxs .boxlist .row b{color:var(--ink2);font-weight:600}
#zxs .boxlist .row span{color:var(--soft);font-size:.85rem;white-space:nowrap}

/* stats */
#zxs .stats{background:var(--ink);color:var(--cream);text-align:center;padding:clamp(3.5rem,7vw,6rem) clamp(1.4rem,4vw,4rem)}
#zxs .stats .row{max-width:1000px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr)}
#zxs .stats .cell{padding:14px 16px}
#zxs .stats .cell + .cell{border-left:1px solid var(--line-d)}
#zxs .stats .n{font-family:var(--serif);font-weight:300;font-size:clamp(2.8rem,1.8rem + 4.4vw,5rem);color:var(--cream);line-height:.95}
#zxs .stats .n .u{color:var(--gold);font-size:.4em;font-style:italic;margin-left:.08em}
#zxs .stats .l{margin-top:12px;font:500 .7rem/1.5 var(--sans);text-transform:uppercase;letter-spacing:.2em;color:rgba(244,239,231,.6)}
@media(max-width:680px){#zxs .stats .row{grid-template-columns:1fr;gap:8px}#zxs .stats .cell + .cell{border-left:0;border-top:1px solid var(--line-d)}}

/* compare */
#zxs .cmpsec{background:var(--paper);padding:clamp(4.5rem,8vw,7.5rem) clamp(1.4rem,4vw,4rem);text-align:center}
#zxs .cmpsec h2{font-size:clamp(1.9rem,1.4rem + 2.2vw,3rem);margin:18px 0 0}
#zxs .cmpwrap{max-width:860px;margin:clamp(2rem,4vw,3rem) auto 0;overflow-x:auto}
#zxs table.cmp{width:100%;border-collapse:collapse;font-size:.92rem;text-align:left;background:var(--cream);border:1px solid var(--line)}
#zxs .cmp th,#zxs .cmp td{padding:14px 16px;border-bottom:1px solid var(--line)}
#zxs .cmp thead th{background:var(--ink);color:var(--cream);font:600 .74rem/1.2 var(--sans);text-transform:uppercase;letter-spacing:.08em}
#zxs .cmp thead th.us{background:var(--clay-deep)}
#zxs .cmp td:first-child{font-weight:600;color:var(--ink2)}
#zxs .cmp td.us{background:rgba(192,104,63,.07);color:var(--ink2);font-weight:500}
#zxs .cmp tr:last-child td{border-bottom:0}

/* trial */
#zxs .trial{background:var(--cream2);text-align:center;padding:clamp(4.5rem,8vw,7.5rem) clamp(1.4rem,4vw,4rem)}
#zxs .trial .seal{width:116px;height:116px;border-radius:50%;border:1px solid var(--gold);margin:0 auto 28px;display:grid;place-content:center;color:var(--clay)}
#zxs .trial .seal b{font-family:var(--serif);font-weight:300;font-size:2.2rem;line-height:.9;color:var(--ink2)}
#zxs .trial .seal small{font:500 .56rem/1 var(--sans);letter-spacing:.2em;text-transform:uppercase;margin-top:5px;color:var(--clay-deep)}
#zxs .trial h2{font-size:clamp(1.9rem,1.4rem + 2.2vw,3rem)}
#zxs .trial p{max-width:46ch;margin:20px auto 0}
#zxs .btn{display:inline-flex;align-items:center;gap:10px;font:500 .86rem/1 var(--sans);letter-spacing:.08em;text-transform:uppercase;text-decoration:none;padding:17px 32px;cursor:pointer;border:1px solid var(--ink2);color:var(--ink2);background:transparent;margin-top:30px;transition:transform .4s cubic-bezier(.2,.7,.2,1),background .3s,color .3s}
#zxs .btn:hover{background:var(--ink2);color:var(--cream);transform:translateY(-3px)}

@media(max-width:860px){
  #zxs .split{grid-template-columns:1fr}
  #zxs .split .media{min-height:60vh}
  #zxs .split.flip .media{order:0}
}
@media(prefers-reduced-motion:reduce){
  #zxs *,#zxs *::before,#zxs *::after{animation:none!important;transition:none!important}
  #zxs .reveal{opacity:1!important;transform:none!important}
  #zxs .cliprv{clip-path:none!important}
  #zxs .pimg{transform:none!important}
}
</style>

<div id="zxs">

  <!-- MANIFESTO -->
  <section class="manif">
    <div class="reveal">
      <span class="eyebrow center">Made for the last hour of the day</span>
      <p>Lie down. Let the points meet your skin. Breathe until the day <span class="grad">loosens its grip</span>.</p>
      <div class="rule"></div>
    </div>
  </section>

  <!-- RITUAL SPLIT -->
  <section class="split">
    <div class="media pwrap cliprv"><img class="pimg" data-px="46" src="{{ img }}green-meditation.png?v=1782855518" alt="Woman meditating on the Serenity acupressure mat" width="704" height="1339" loading="lazy" decoding="async"></div>
    <div class="copy reveal d1">
      <span class="eyebrow">The ritual</span>
      <h2>Three steps to calm, tonight.</h2>
      <p class="lead">No appointment, no pills, nothing to charge &#8212; just twenty honest minutes.</p>
      <div class="steps">
        <div class="step"><span class="num">01</span><div><h3>Unroll it</h3><p>Lay the mat where you rest &#8212; bed, couch or floor &#8212; and set the pillow beneath your neck.</p></div></div>
        <div class="step"><span class="num">02</span><div><h3>Lie back slowly</h3><p>A few minutes of sharp, bright warmth, then a spreading ease as the muscles settle.</p></div></div>
        <div class="step"><span class="num">03</span><div><h3>Let go</h3><p>Stay twenty minutes, most evenings. Many drift off before it&rsquo;s done.</p></div></div>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="stats">
    <div class="row">
      <div class="cell reveal"><div class="n"><span class="cnt" data-to="20">0</span><span class="u">min</span></div><div class="l">A day is all it takes</div></div>
      <div class="cell reveal d1"><div class="n"><span class="cnt" data-to="6000">0</span><span class="u">+</span></div><div class="l">Pressure points</div></div>
      <div class="cell reveal d2"><div class="n"><span class="cnt" data-to="60">0</span><span class="u">nights</span></div><div class="l">Money-back trial</div></div>
    </div>
  </section>

  <!-- MATERIALS SPLIT -->
  <section class="split flip">
    <div class="media pwrap cliprv"><img class="pimg" data-px="46" src="{{ img }}blackwhite-macro.png?v=1782855518" alt="Close-up of the lotus-shaped acupressure points" width="704" height="1339" loading="lazy" decoding="async"></div>
    <div class="copy reveal d1">
      <span class="eyebrow">Made of real things</span>
      <h2>Texture your skin actually wants.</h2>
      <p class="lead">A soft, breathable cover over a dense, supportive core &#8212; thousands of lotus-shaped points, evenly spaced for steady, calming pressure.</p>
      <div class="boxlist">
        <div class="row"><b>Acupressure mat</b><span>6,000+ contact points</span></div>
        <div class="row"><b>Contoured neck pillow</b><span>reaches the curve</span></div>
        <div class="row"><b>Carry &amp; storage bag</b><span>included</span></div>
      </div>
    </div>
  </section>

  <!-- COMPARE -->
  <section class="cmpsec">
    <div class="reveal">
      <span class="eyebrow center">Why Serenity</span>
      <h2>One quiet investment in your evenings.</h2>
      <div class="cmpwrap">
        <table class="cmp">
          <thead><tr><th>&nbsp;</th><th class="us">Serenity Set</th><th>Massage visits</th><th>Painkillers</th></tr></thead>
          <tbody>
            <tr><td>Cost over time</td><td class="us">One-time $49.99</td><td>$80+ each visit</td><td>Ongoing</td></tr>
            <tr><td>Use it anytime</td><td class="us">At home, nightly</td><td>By appointment</td><td>Anytime</td></tr>
            <tr><td>Drug-free</td><td class="us">Yes</td><td>Yes</td><td>No</td></tr>
            <tr><td>Helps you wind down</td><td class="us">Built for it</td><td>Sometimes</td><td>No</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- TRIAL -->
  <section class="trial">
    <div class="reveal">
      <div class="seal"><b>60</b><small>nights</small></div>
      <span class="eyebrow center">The 60-night trial</span>
      <h2>Sleep on it. Literally.</h2>
      <p>Use the Serenity Set every evening for sixty nights. If your shoulders, your evenings or your sleep aren&rsquo;t the better for it, send it back for a full refund &#8212; return shipping on us.</p>
      <a class="btn" href="#MainContent">Choose your set</a>
    </div>
  </section>

</div>

<script>
(function(){
  var zxs=document.getElementById('zxs');if(!zxs)return;
  var reduce=window.matchMedia&&window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  function runCount(el){
    var to=+el.getAttribute('data-to'),t0=null,dur=1600;
    function step(ts){if(!t0)t0=ts;var p=Math.min((ts-t0)/dur,1);var e=1-Math.pow(1-p,3);
      var v=Math.floor(e*to);el.textContent=(to>=1000?v.toLocaleString('en-US'):v);
      if(p<1)requestAnimationFrame(step);else el.textContent=(to>=1000?to.toLocaleString('en-US'):to);}
    requestAnimationFrame(step);
  }
  var items=zxs.querySelectorAll('.reveal,.cliprv');
  if(reduce||!('IntersectionObserver'in window)){
    items.forEach(function(el){el.classList.add('is-in');});
    zxs.querySelectorAll('.cnt').forEach(function(c){c.textContent=(+c.getAttribute('data-to')).toLocaleString('en-US');});
  } else {
    var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){
      e.target.classList.add('is-in');
      var cs=e.target.querySelectorAll?e.target.querySelectorAll('.cnt'):[];
      cs.forEach(function(c){if(!c.dataset.done){c.dataset.done=1;runCount(c);}});
      io.unobserve(e.target);}});},{threshold:.12,rootMargin:'0px 0px -7% 0px'});
    items.forEach(function(el){io.observe(el);});
  }
  var pe=[].slice.call(zxs.querySelectorAll('[data-px]')),ticking=false;
  function px(){ticking=false;var vh=window.innerHeight;
    for(var i=0;i<pe.length;i++){var el=pe[i],r=el.getBoundingClientRect();
      if(r.bottom<-300||r.top>vh+300)continue;
      var prog=(r.top+r.height/2-vh/2)/(vh/2+r.height/2);if(prog>1)prog=1;if(prog<-1)prog=-1;
      var f=parseFloat(el.getAttribute('data-px'))||40;el.style.transform='translate3d(0,'+(-prog*f).toFixed(1)+'px,0)';}}
  function onPx(){if(!ticking){ticking=true;requestAnimationFrame(px);}}
  if(!reduce){window.addEventListener('scroll',onPx,{passive:true});window.addEventListener('resize',onPx,{passive:true});px();}
})();
</script>

