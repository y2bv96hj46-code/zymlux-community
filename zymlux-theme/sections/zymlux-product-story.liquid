@media(prefers-reduced-motion:reduce){
  #zxs *,#zxs *::before,#zxs *::after{animation:none!important;transition:none!important}
  #zxs .reveal{opacity:1!important;transform:none!important}
  #zxs .cliprv{clip-path:none!important}
  #zxs .pimg{transform:none!important}
  #zxs .marq .track{animation:none!important}
}
</style>

