#zxs details[open] summary .chev{transform:rotate(180deg)}
#zxs .ans{padding:0 4px 22px;font-size:.95rem;color:var(--muted);max-width:60ch}
#zxs .fine{max-width:620px;margin:clamp(2.5rem,4vw,3.5rem) auto 0;text-align:center;font-size:.78rem;color:var(--soft);font-style:italic}

@media(max-width:860px){
  #zxs .split{grid-template-columns:1fr}
  #zxs .split .media{min-height:60vh}
  #zxs .split.flip .media{order:0}
