#zxs .boxlist{margin-top:26px;border-top:1px solid var(--line)}
#zxs .boxlist .row{display:flex;justify-content:space-between;gap:16px;padding:13px 2px;border-bottom:1px solid var(--line);font-size:.95rem}
#zxs .boxlist .row b{color:var(--ink2);font-weight:600}
#zxs .boxlist .row span{color:var(--soft);font-size:.85rem;white-space:nowrap}

/* stats */
#zxs .stats{background:var(--ink);color:var(--cream);text-align:center;padding:clamp(3.5rem,7vw,6rem) clamp(1.4rem,4vw,4rem)}
#zxs .stats .row{max-width:1000px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr)}
#zxs .stats .cell{padding:14px 16px}
