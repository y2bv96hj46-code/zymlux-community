  --serif:'Fraunces',Georgia,serif;--sans:'Inter','Helvetica Neue',Arial,sans-serif;
  font-family:var(--sans);color:var(--muted);line-height:1.7;overflow:hidden;background:var(--cream);
  -webkit-font-smoothing:antialiased;font-size:16px}
#zxs *{box-sizing:border-box;margin:0;padding:0}
#zxs img{display:block;max-width:100%}
#zxs h2,#zxs h3{font-family:var(--serif);font-weight:300;color:var(--ink2);letter-spacing:-.02em;line-height:1.1}
#zxs .grad{background:linear-gradient(95deg,var(--gold2),var(--gold) 55%,var(--clay));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;color:transparent;font-style:italic}
#zxs .eyebrow{display:inline-flex;align-items:center;gap:13px;font:500 .72rem/1 var(--sans);text-transform:uppercase;letter-spacing:.3em;color:var(--gold)}
#zxs .eyebrow::before{content:"";width:30px;height:1px;background:var(--gold)}
#zxs .eyebrow.center::after{content:"";width:30px;height:1px;background:var(--gold)}
#zxs .sympt .eyebrow,#zxs .split .eyebrow,#zxs .cmpsec .eyebrow,#zxs .trial .eyebrow,#zxs .revs .eyebrow,#zxs .faqsec .eyebrow{color:#7D6130}
#zxs .sympt .eyebrow::before,#zxs .split .eyebrow::before,#zxs .cmpsec .eyebrow::before,#zxs .trial .eyebrow::before,#zxs .revs .eyebrow::before,#zxs .faqsec .eyebrow::before,#zxs .sympt .eyebrow.center::after,#zxs .cmpsec .eyebrow.center::after,#zxs .trial .eyebrow.center::after,#zxs .revs .eyebrow.center::after,#zxs .faqsec .eyebrow.center::after{background:#7D6130}
#zxs .reveal{opacity:0;transform:translateY(26px);transition:opacity 1s cubic-bezier(.2,.6,.2,1),transform 1s cubic-bezier(.2,.6,.2,1)}
