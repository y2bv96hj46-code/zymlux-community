#zxs .pwrap{position:relative;overflow:hidden}
#zxs .pimg{position:absolute;left:0;top:-14%;width:100%;height:128%;object-fit:cover;will-change:transform;backface-visibility:hidden}

/* marquee */
#zxs .marq{background:var(--ink);color:var(--gold);overflow:hidden;border-top:1px solid rgba(194,160,106,.14);border-bottom:1px solid rgba(194,160,106,.14);padding:15px 0}
#zxs .marq .track{display:inline-flex;white-space:nowrap;will-change:transform;animation:zxsmarq 32s linear infinite}
#zxs .marq span{display:inline-flex;align-items:center;font:500 .78rem/1 var(--sans);text-transform:uppercase;letter-spacing:.24em;color:rgba(226,203,160,.92)}
#zxs .marq .sep{margin:0 26px;color:var(--gold);opacity:.7}
@keyframes zxsmarq{to{transform:translateX(-50%)}}

/* symptoms */
#zxs .sympt{background:var(--paper);text-align:center;padding:clamp(4.5rem,8.5vw,8rem) clamp(1.4rem,4vw,4rem)}
#zxs .sympt h2{font-size:clamp(2rem,1.4rem + 2.6vw,3.3rem);margin:18px 0 0}
#zxs .sympt .intro{margin:18px auto 0;max-width:46ch;color:var(--soft)}
#zxs .slist{max-width:620px;margin:clamp(2rem,4vw,3rem) auto 0;text-align:left}
#zxs .slist .s{display:flex;gap:18px;align-items:baseline;padding:15px 4px;border-bottom:1px solid var(--line);font-family:var(--serif);font-weight:300;font-style:italic;font-size:clamp(1.02rem,.95rem + .5vw,1.25rem);line-height:1.5;color:var(--ink2)}
