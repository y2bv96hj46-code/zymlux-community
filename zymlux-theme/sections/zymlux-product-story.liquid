<style>
#zxs{--cream:#F4EFE7;--cream2:#EBE3D5;--paper:#FBF9F4;--ink:#1F2723;--ink2:#36423C;--muted:#4A554F;--soft:#6B746E;
  --clay:#C0683F;--clay-deep:#9E4F2E;--gold:#C2A06A;--gold2:#E3CBA0;
