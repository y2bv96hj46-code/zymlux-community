#zxs summary{display:flex;align-items:center;justify-content:space-between;gap:20px;padding:22px 4px;cursor:pointer;list-style:none;font:400 1.12rem/1.4 var(--serif);color:var(--ink2)}
#zxs summary::-webkit-details-marker{display:none}
