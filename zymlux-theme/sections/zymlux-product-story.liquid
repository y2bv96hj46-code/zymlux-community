#zxs .slist .s i{flex:none;font-style:normal;font-family:var(--sans);font-size:.62rem;letter-spacing:.1em;color:var(--gold);transform:translateY(-2px)}
#zxs .sympt .foot{margin:30px auto 0;max-width:46ch;color:var(--muted)}
