#zxs .manif .rule{width:1px;height:50px;background:linear-gradient(var(--gold),transparent);margin:36px auto 0}

/* splits */
#zxs .split{display:grid;grid-template-columns:1fr 1fr;align-items:stretch;min-height:clamp(480px,72vh,740px)}
