#zxs .cmpsec h2{font-size:clamp(1.9rem,1.4rem + 2.2vw,3rem);margin:18px 0 0}
#zxs .cmpwrap{max-width:860px;margin:clamp(2rem,4vw,3rem) auto 0;overflow-x:auto}
#zxs table.cmp{width:100%;border-collapse:collapse;font-size:.92rem;text-align:left;background:var(--cream);border:1px solid var(--line)}
#zxs .cmp th,#zxs .cmp td{padding:14px 16px;border-bottom:1px solid var(--line)}
#zxs .cmp thead th{background:var(--ink);color:var(--cream);font:600 .74rem/1.2 var(--sans);text-transform:uppercase;letter-spacing:.08em}
